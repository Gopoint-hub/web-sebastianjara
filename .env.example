# --- Server runtime ---
NODE_ENV=development
PORT=3000

# --- Database ---
# MySQL connection string used by Drizzle (server/db.ts, drizzle.config.ts)
DATABASE_URL=mysql://user:password@localhost:3306/sebastianjara

# --- Auth / OAuth (Manus) ---
# JWT secret used to sign session cookies
JWT_SECRET=replace-with-a-long-random-string
# OAuth provider base URL
OAUTH_SERVER_URL=https://oauth.example.com
# Open ID of the owner/admin user
OWNER_OPEN_ID=

# --- Manus Forge proxy (only required if using llm/voice/map/image features in server/_core) ---
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# --- Vite (client) ---
# App ID exposed to the client for OAuth
VITE_APP_ID=
# OAuth portal URL surfaced in client/src/const.ts
VITE_OAUTH_PORTAL_URL=

# --- Analytics (Umami) ---
# Both are interpolated into client/index.html at build/serve time
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
